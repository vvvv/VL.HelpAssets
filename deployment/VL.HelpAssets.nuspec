<?xml version="1.0"?>

<package xmlns="http://schemas.microsoft.com/packaging/2011/10/nuspec.xsd">
  <metadata>
    <id>VL.HelpAssets</id>
    <version>0.0.1-alpha</version>
    <title>VL.HelpAssets</title>
    <authors>vvvv</authors>
    <projectUrl>https://github.com/vvvv/VL.HelpAssets</projectUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Assets for VL help patches</description>
    <tags>VL</tags>
    <license type="expression">LGPL-3.0-only</license>
    <icon>icon\nugeticon.png</icon>
    <readme>docs\README.md</readme>
  </metadata>
  <files>
    <file src="..\sounds\**" target="sounds\" exclude="" />
    <file src="..\images\**" target="images\" exclude="" />
    <file src="..\misc\**" target="misc\" exclude="" />
    <file src="..\models\**" target="models\" exclude="" />
    <file src="..\svgs\**" target="svgs\" exclude="" />
    <file src="..\movies\**" target="movies\" exclude="" />
    <file src="..\lib\**\*.dll" target="lib\" exclude="" />
    <file src="..\*.vl" target="" exclude="" />
    <file src="..\help\**" target="help\" exclude="" />
    <file src="nugeticon.png" target="icon\" />
    <file src="..\README.md" target="docs\" />
  </files>
</package>
