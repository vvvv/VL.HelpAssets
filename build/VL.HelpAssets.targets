<Project>
  <ItemGroup>
    <Assets Include="$(MSBuildThisFileDirectory)\..\assets\**" />
  </ItemGroup>
  <Target Name="CopyAssets" AfterTargets="Publish">
  
    <Message Text="Copying Assets" Importance="high"/>
	<Copy
        SourceFiles="@(Assets)" DestinationFiles="@(Assets->'$(VLExportPath)\$(TargetName)\assets\%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="True"
    />
  </Target>
</Project>